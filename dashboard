  .settings-form{display:grid; grid-template-columns:1fr 1fr; gap:16px; max-width:640px;}
  .settings-form .full{grid-column:1/-1;}
  .settings-form label{font-size:12.5px; color:var(--muted); margin-bottom:6px; display:block;}

  .toast{
    position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--panel-2); border:1px solid var(--blue); color:var(--text);
    padding:14px 22px; border-radius:10px; font-size:14px; z-index:200;
    opacity:0; pointer-events:none; transition:all 0.35s;
    display:flex; align-items:center; gap:10px;
  }
  .toast.show{opacity:1; transform:translateX(-50%) translateY(0);}

  .skeleton{background:linear-gradient(90deg, var(--panel-2) 25%, var(--line) 37%, var(--panel-2) 63%); background-size:400px 100%; animation:shimmer 1.4s infinite linear; border-radius:6px;}

