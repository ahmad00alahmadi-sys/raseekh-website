<!DOCTYPE html>
<html lang="ar" dir="rtl" id="htmlRoot">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title id="pageTitle">لوحة تحكم العميل — رَسِيخ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Almarai:wght@400;700;800&family=IBM+Plex+Sans+Arabic:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root{
    --bg:#17171A;
    --panel:#1F1F23;
    --panel-2:#28282D;
    --line:#3B3A34;
    --blue:#D4AF37;
    --coral:#B8912F;
    --text:#F3F0E8;
    --muted:#9C9585;
    --success:#22543d;
    --success-bg:#c6f6d5;
    --error:#742a2a;
    --error-bg:#fed7d7;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'IBM Plex Sans Arabic', sans-serif;
    line-height:1.7;
    overflow-x:hidden;
  }
  body.lang-en{font-family:'Inter', sans-serif;}
  body::before{
    content:"";
    position:fixed; inset:0;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size:48px 48px;
    opacity:0.15;
    pointer-events:none;
    z-index:0;
  }
  .wrap{max-width:1120px;margin:0 auto;padding:0 24px;position:relative;z-index:1;}
  h1,h2,h3{font-family:'Almarai', sans-serif;}
  body.lang-en h1, body.lang-en h2, body.lang-en h3{font-family:'Inter', sans-serif;}
  .mono{font-family:'IBM Plex Mono', monospace; letter-spacing:0.02em;}
  a{color:inherit;text-decoration:none;}

  /* NAV & HEADER ACTIONS */
  header{
    position:sticky; top:0; z-index:50;
    background:rgba(11,11,13,0.85);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  nav{display:flex;align-items:center;justify-content:space-between;padding:18px 24px;max-width:1120px;margin:0 auto; gap:16px;}
  .logo{font-family:'Almarai',sans-serif;font-weight:800;font-size:22px;color:var(--text);}
  .logo span{color:var(--blue);}
  .nav-links{display:flex;gap:28px;font-size:15px;color:var(--muted); align-items:center;}
  .nav-links a:hover{color:var(--blue);}
  
  .nav-actions{display:flex; align-items:center; gap:12px;}
  .nav-btn{
    background:none; border:1px solid var(--line); color:var(--text);
    padding:8px 16px; border-radius:6px; font-size:14px; cursor:pointer; font-family:inherit;
  }
  .nav-btn:hover{border-color:var(--blue); color:var(--blue);}
  .nav-btn.primary{
    background:var(--coral); border-color:var(--coral); color:#0B0B0D; font-weight:600;
  }
  .nav-btn.primary:hover{background:var(--blue); border-color:var(--blue); color:#0B0B0D;}
  
  .lang-btn{
    border:1px solid var(--line); background:var(--panel); color:var(--text);
    padding:8px 14px; border-radius:6px; font-size:13px; font-family:'IBM Plex Mono',monospace;
    cursor:pointer;
  }
  .lang-btn:hover{border-color:var(--blue); color:var(--blue);}
  .nav-toggle{display:none; flex-direction:column; gap:5px; cursor:pointer; background:none; border:none;}
  .nav-toggle span{width:24px;height:2px;background:var(--text);display:block;}

  /* HERO */
  .hero{padding:100px 0 80px; position:relative;}
  .eyebrow{
    display:inline-flex; align-items:center; gap:8px;
    font-family:'IBM Plex Mono',monospace; font-size:13px; color:var(--blue);
    border:1px solid var(--line); background:var(--panel); padding:6px 14px; border-radius:100px;
    margin-bottom:28px;
  }
  .eyebrow::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--coral);}
  .hero h1{
    font-size:clamp(34px,5.5vw,58px); font-weight:800; line-height:1.25;
    max-width:800px; margin-bottom:22px;
  }
  .hero h1 em{font-style:normal; color:var(--blue);}
  .hero p{font-size:18px; color:var(--muted); max-width:560px; margin-bottom:36px;}
  .btn-row{display:flex; gap:16px; flex-wrap:wrap; margin-bottom:80px;}
  .btn-primary{
    background:var(--coral); color:#0B0B0D; font-weight:700;
    padding:15px 30px; border-radius:8px; font-size:15px;
    box-shadow:0 10px 24px -8px rgba(184,145,47,0.45);
  }
  .btn-secondary{
    border:1px solid var(--line); background:var(--panel); color:var(--text);
    padding:15px 30px; border-radius:8px; font-size:15px;
  }
  .btn-secondary:hover{border-color:var(--blue); color:var(--blue);}

  /* SCHEMATIC DIAGRAM */
  .schematic{
    position:relative; background:var(--panel);
    border:1px solid var(--line); border-radius:16px;
    padding:50px 20px; overflow:hidden;
    box-shadow:0 20px 50px -30px rgba(0,0,0,0.6);
  }
  .schematic svg{width:100%; height:auto; display:block;}
  .diagram-path{
    fill:none; stroke:var(--coral); stroke-width:2.5;
    stroke-dasharray:400; stroke-dashoffset:400;
    animation:draw 1.8s ease forwards;
  }
  .diagram-path.d2{animation-delay:0.2s;}
  .diagram-path.d3{animation-delay:0.4s;}
  @keyframes draw{to{stroke-dashoffset:0;}}
  .node{fill:var(--panel-2); stroke:var(--line); stroke-width:1.5;}
  .node-core{fill:var(--blue); stroke:var(--blue);}
  .node-label{font-family:'IBM Plex Sans Arabic',sans-serif; font-size:15px; fill:var(--text); font-weight:500;}
  .node-tag{font-family:'IBM Plex Mono',monospace; font-size:10px; fill:var(--muted);}

  section{padding:90px 0; position:relative;}
  .section-head{max-width:600px; margin-bottom:56px;}
  .section-head .eyebrow{margin-bottom:18px;}
  .section-head h2{font-size:clamp(28px,4vw,38px); font-weight:800; margin-bottom:14px;}
  .section-head p{color:var(--muted); font-size:16px;}

  .services-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:24px;}
  .service-card{
    background:var(--panel); border:1px solid var(--line); border-radius:14px;
    padding:32px 26px; transition:border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .service-card:hover{border-color:var(--blue); transform:translateY(-4px); box-shadow:0 16px 32px -20px rgba(212,175,55,0.25);}
  .service-tag{font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--coral); display:block; margin-bottom:18px;}
  .service-card h3{font-size:20px; margin-bottom:12px; font-weight:700;}
  .service-card p{color:var(--muted); font-size:15px;}

  .process-list{display:flex; flex-direction:column;}
  .process-item{display:grid; grid-template-columns:80px 1fr; gap:24px; padding:28px 0; border-bottom:1px solid var(--line);}
  .process-item:first-child{border-top:1px solid var(--line);}
  .process-num{font-family:'IBM Plex Mono',monospace; font-size:14px; color:var(--blue);}
  .process-item h3{font-size:19px; margin-bottom:8px; font-weight:700;}
  .process-item p{color:var(--muted); font-size:15px; max-width:560px;}

  .team-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:24px;}
  .team-card{background:var(--panel-2); border:1px solid var(--line); border-radius:14px; padding:30px 24px;}
  .team-icon{
    width:44px;height:44px;border-radius:10px;background:var(--panel);
    display:flex;align-items:center;justify-content:center;
    color:var(--blue); font-family:'IBM Plex Mono',monospace; font-size:13px;
    margin-bottom:18px; border:1px solid var(--line);
  }
  .team-card h3{font-size:17px; margin-bottom:8px;}
  .team-card p{color:var(--muted); font-size:14px;}

  /* CONTACT BOX */
  .contact-box{
    background:var(--panel); border:1px solid var(--line); border-radius:18px;
    padding:56px 40px; display:grid; grid-template-columns:1fr 1fr; gap:48px;
    box-shadow:0 20px 50px -30px rgba(0,0,0,0.6); margin-bottom:40px;
  }
  .contact-box h2{font-size:30px; margin-bottom:14px; font-weight:800;}
  .contact-box p{color:var(--muted); margin-bottom:26px;}
  .contact-info{display:flex; flex-direction:column; gap:14px; font-size:15px;}
  .contact-info .mono{color:var(--blue);}
  form {display:flex; flex-direction:column; gap:14px;}
  input,select,textarea{
    background:var(--panel-2); border:1px solid var(--line); color:var(--text);
    padding:13px 16px; border-radius:8px; font-family:inherit; font-size:14px;
  }
  input:focus,select:focus,textarea:focus{outline:2px solid var(--blue); border-color:transparent;}
  textarea{resize:vertical; min-height:120px;}
  
  .submit-btn {
    background:var(--coral); color:#0B0B0D; font-weight:700;
    padding:14px; border:none; border-radius:8px; cursor:pointer; font-size:15px; font-family:inherit;
  }
  .submit-btn:hover {background:var(--blue);}

  /* AGREEMENT CHECKBOX INSIDE AUTH MODAL */
  .agreement-container {
    display: flex; align-items: flex-start; gap: 10px; margin: 10px 0; font-size: 13px; color: var(--muted);
  }
  .agreement-container input { width: auto; margin-top: 4px; cursor: pointer; accent-color: var(--blue); }
  .agreement-link { color: var(--blue); text-decoration: underline; cursor: pointer; }

  footer{border-top:1px solid var(--line); padding:32px 0; text-align:center; color:var(--muted); font-size:14px;}
  footer .footer-links{display:flex; gap:20px; justify-content:center; margin-top:12px; flex-wrap:wrap;}
  footer .footer-links a{color:var(--muted); font-size:13px;}
  footer .footer-links a:hover{color:var(--blue);}

  /* MODALS STYLE */
  .modal-overlay{
    display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7);
    z-index:100; align-items:center; justify-content:center; padding:20px;
    backdrop-filter: blur(4px);
  }
  .modal-overlay.active{display:flex;}
  .modal-box{
    background:var(--panel); border:1px solid var(--line); border-radius:16px;
    max-width:500px; width:100%; max-height:85vh; overflow-y:auto; padding:36px;
    position:relative;
  }
  .modal-box.wide { max-width: 680px; }
  .modal-close{
    position:absolute; top:18px; left:18px; background:none; border:none;
    color:var(--muted); font-size:22px; cursor:pointer; line-height:1;
  }
  body.lang-en .modal-close{left:auto; right:18px;}
  .modal-box h2{font-size:24px; margin-bottom:18px;}
  .modal-box h3{font-size:16px; margin:20px 0 8px; color:var(--blue);}
  .modal-box p{color:var(--muted); font-size:14px; margin-bottom:10px;}

  @media (max-width:860px){
    .nav-links{display:none;}
    .nav-toggle{display:flex;}
    .services-grid, .team-grid{grid-template-columns:1fr;}
    .contact-box{grid-template-columns:1fr; padding:36px 24px;}
    .process-item{grid-template-columns:50px 1fr;}
  }

  /* ============================= */
  /* CUSTOMER DASHBOARD             */
  /* ============================= */
  #dashboardView{
    display:none;
    min-height:100vh;
    grid-template-columns:260px 1fr;
    position:relative; z-index:1;
  }
  #dashboardView.active{display:grid;}

  @keyframes fadeSlideIn{
    from{opacity:0; transform:translateY(14px);}
    to{opacity:1; transform:translateY(0);}
  }
  @keyframes fadeIn{ from{opacity:0;} to{opacity:1;} }
  @keyframes popIn{
    from{opacity:0; transform:scale(0.9);}
    to{opacity:1; transform:scale(1);}
  }
  @keyframes slideDown{
    from{opacity:0; max-height:0;}
    to{opacity:1; max-height:400px;}
  }
  @keyframes pulseDot{
    0%,100%{box-shadow:0 0 0 0 rgba(212,175,55,0.5);}
    50%{box-shadow:0 0 0 6px rgba(212,175,55,0);}
  }
  @keyframes shimmer{
    0%{background-position:-200px 0;}
    100%{background-position:200px 0;}
  }

  .dash-sidebar{
    background:var(--panel);
    border-left:1px solid var(--line);
    padding:26px 18px;
    display:flex; flex-direction:column;
    position:sticky; top:0; height:100vh;
  }
  body.lang-en .dash-sidebar{border-left:none; border-right:1px solid var(--line);}
  .dash-logo{display:flex; align-items:center; gap:10px; padding:0 8px 26px; margin-bottom:20px; border-bottom:1px solid var(--line);}
  .dash-logo .logo{font-size:20px;}
  .dash-nav{display:flex; flex-direction:column; gap:4px; flex:1;}
  .dash-nav-item{
    display:flex; align-items:center; gap:12px;
    padding:12px 14px; border-radius:9px; cursor:pointer;
    color:var(--muted); font-size:14.5px; border:1px solid transparent;
    transition:background 0.2s, color 0.2s, border-color 0.2s;
    background:none; width:100%; text-align:right; font-family:inherit;
  }
  body.lang-en .dash-nav-item{text-align:left;}
  .dash-nav-item .dni{width:18px; text-align:center; font-family:'IBM Plex Mono',monospace; font-size:13px;}
  .dash-nav-item:hover{color:var(--text); background:var(--panel-2);}
  .dash-nav-item.active{
    color:var(--blue); background:var(--panel-2); border-color:var(--line);
    font-weight:600;
  }
  .dash-nav-item.active .dni{color:var(--blue);}
  .dash-foot{border-top:1px solid var(--line); padding-top:16px; margin-top:10px;}
  .dash-user{display:flex; align-items:center; gap:10px; padding:8px; margin-bottom:10px;}
  .dash-avatar{
    width:36px;height:36px;border-radius:50%; background:linear-gradient(135deg,var(--blue),var(--coral));
    display:flex; align-items:center; justify-content:center; color:#0B0B0D; font-weight:800; font-size:14px;
    flex-shrink:0;
  }
  .dash-user-info{overflow:hidden;}
  .dash-user-email{font-size:12.5px; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .dash-user-status{font-size:11px; color:var(--muted); display:flex; align-items:center; gap:5px;}
  .dash-user-status::before{content:""; width:6px; height:6px; border-radius:50%; background:#3aa76d; animation:pulseDot 2s infinite;}
  .dash-logout-btn{
    width:100%; background:none; border:1px solid var(--line); color:var(--muted);
    padding:10px; border-radius:8px; cursor:pointer; font-size:13.5px; font-family:inherit;
  }
  .dash-logout-btn:hover{border-color:#a24545; color:#e08585;}

  .dash-main{padding:32px 40px; overflow-x:hidden;}
  .dash-topbar{display:flex; align-items:center; justify-content:space-between; margin-bottom:30px; gap:16px; flex-wrap:wrap;}
  .dash-topbar h1{font-size:26px; font-weight:800;}
  .dash-breadcrumb{font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--muted); margin-top:4px;}
  .dash-breadcrumb span{color:var(--blue);}
  .dash-clock{font-family:'IBM Plex Mono',monospace; font-size:13px; color:var(--muted); border:1px solid var(--line); background:var(--panel); padding:8px 14px; border-radius:8px;}

  .dash-page{display:none;}
  .dash-page.active{display:block; animation:fadeSlideIn 0.4s ease;}

  .stat-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:18px; margin-bottom:32px;}
  .stat-card{
    background:var(--panel); border:1px solid var(--line); border-radius:14px; padding:22px;
    position:relative; overflow:hidden;
  }
  .stat-card::after{
    content:""; position:absolute; inset:0; opacity:0;
    background:radial-gradient(circle at 100% 0%, rgba(212,175,55,0.15), transparent 60%);
    transition:opacity 0.3s;
  }
  .stat-card:hover::after{opacity:1;}
  .stat-card:hover{border-color:var(--blue); transform:translateY(-3px); transition:transform 0.25s, border-color 0.25s;}
  .stat-label{font-size:13px; color:var(--muted); margin-bottom:10px; display:flex; align-items:center; justify-content:space-between;}
  .stat-icon{font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--coral); border:1px solid var(--line); padding:2px 7px; border-radius:5px;}
  .stat-value{font-size:32px; font-weight:800; font-family:'IBM Plex Mono',monospace;}
  .stat-trend{font-size:12px; margin-top:8px; color:#3aa76d;}
  .stat-trend.down{color:#c76767;}

  .dash-grid-2{display:grid; grid-template-columns:1.4fr 1fr; gap:20px; margin-bottom:20px;}
  .panel-card{background:var(--panel); border:1px solid var(--line); border-radius:14px; padding:26px;}
  .panel-card h3{font-size:16px; margin-bottom:18px; display:flex; align-items:center; justify-content:space-between;}
  .panel-card h3 .see-all{font-size:12px; color:var(--blue); font-weight:400; cursor:pointer;}

  .timeline-item{display:flex; gap:14px; padding:14px 0; border-bottom:1px solid var(--line);}
  .timeline-item:last-child{border-bottom:none;}
  .timeline-dot{width:8px; height:8px; border-radius:50%; background:var(--blue); margin-top:6px; flex-shrink:0;}
  .timeline-body p{color:var(--text); font-size:14px; margin-bottom:3px;}
  .timeline-body span{color:var(--muted); font-size:12px; font-family:'IBM Plex Mono',monospace;}

  .progress-ring-wrap{display:flex; flex-direction:column; align-items:center; justify-content:center; gap:14px; padding:10px 0;}
  .progress-ring-label{font-size:13px; color:var(--muted); text-align:center;}
  .progress-ring-label strong{color:var(--text); display:block; font-size:15px; margin-bottom:2px;}

  .dash-table-wrap{background:var(--panel); border:1px solid var(--line); border-radius:14px; overflow:hidden;}
  .dash-table-head{
    display:flex; align-items:center; justify-content:space-between; padding:20px 24px;
    border-bottom:1px solid var(--line); gap:16px; flex-wrap:wrap;
  }
  .dash-table-head h3{font-size:17px;}
  .dash-filters{display:flex; gap:8px; flex-wrap:wrap;}
  .filter-chip{
    font-size:12.5px; padding:7px 14px; border-radius:100px; border:1px solid var(--line);
    background:var(--panel-2); color:var(--muted); cursor:pointer; font-family:inherit;
  }
  .filter-chip.active{background:var(--coral); border-color:var(--coral); color:#0B0B0D; font-weight:600;}
  table.req-table{width:100%; border-collapse:collapse;}
  table.req-table th{
    text-align:right; font-size:12px; color:var(--muted); font-weight:500; padding:12px 24px;
    border-bottom:1px solid var(--line); font-family:'IBM Plex Mono',monospace;
  }
  body.lang-en table.req-table th{text-align:left;}
  table.req-table td{padding:16px 24px; border-bottom:1px solid var(--line); font-size:14px;}
  table.req-table tbody tr{opacity:0; animation:fadeSlideIn 0.4s ease forwards;}
  table.req-table tbody tr:hover{background:var(--panel-2);}
  table.req-table tr:last-child td{border-bottom:none;}
  .req-id{font-family:'IBM Plex Mono',monospace; color:var(--muted); font-size:12.5px;}
  .row-actions{display:flex; gap:6px;}
  .row-action-btn{
    width:30px; height:30px; border-radius:7px; border:1px solid var(--line); background:var(--panel-2);
    color:var(--muted); cursor:pointer; font-size:13px; display:inline-flex; align-items:center; justify-content:center;
    transition:border-color 0.2s, color 0.2s, background 0.2s;
  }
  .row-action-btn:hover{border-color:var(--blue); color:var(--blue);}
  .row-action-btn.danger:hover{border-color:#c76767; color:#e08585;}

  .badge{
    display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:100px;
    font-size:12px; font-weight:600;
  }
  .badge::before{content:""; width:6px; height:6px; border-radius:50%;}
  .badge.pending{background:rgba(212,175,55,0.15); color:var(--blue);}
  .badge.pending::before{background:var(--blue);}
  .badge.progress{background:rgba(80,140,220,0.15); color:#6fa8f5;}
  .badge.progress::before{background:#6fa8f5;}
  .badge.done{background:rgba(58,167,109,0.15); color:#3aa76d;}
  .badge.done::before{background:#3aa76d;}
  .badge.rejected{background:rgba(199,103,103,0.15); color:#c76767;}
  .badge.rejected::before{background:#c76767;}

  .empty-state{padding:60px 24px; text-align:center; color:var(--muted);}
  .empty-state .es-icon{font-size:34px; margin-bottom:14px; opacity:0.6;}

  .new-req-btn{
    background:var(--coral); color:#0B0B0D; font-weight:700; border:none;
    padding:11px 20px; border-radius:8px; cursor:pointer; font-size:14px; font-family:inherit;
  }
  .new-req-btn:hover{background:var(--blue);}

  .invoice-row{display:flex; align-items:center; justify-content:space-between; padding:16px 0; border-bottom:1px solid var(--line);}
  .invoice-row:last-child{border-bottom:none;}
  .invoice-info p{font-size:14px; margin-bottom:3px;}
  .invoice-info span{font-size:12px; color:var(--muted); font-family:'IBM Plex Mono',monospace;}
  .invoice-amount{font-family:'IBM Plex Mono',monospace; font-weight:600;}

  .faq-item{border:1px solid var(--line); border-radius:10px; margin-bottom:10px; overflow:hidden;}
  .faq-q{padding:16px 18px; cursor:pointer; display:flex; justify-content:space-between; align-items:center; font-size:14.5px; background:var(--panel-2);}
  .faq-q .faq-arrow{transition:transform 0.25s; color:var(--blue);}
  .faq-item.open .faq-arrow{transform:rotate(180deg);}
  .faq-a{padding:0 18px; max-height:0; overflow:hidden; opacity:0; color:var(--muted); font-size:13.5px; transition:all 0.3s;}
