<div class="toast" id="toast"></div>
<script>
  // تهيئة Supabase — نفس المشروع المستخدم في الصفحة الرئيسية (index.html)
  // حتى تبقى جلسة الدخول شغالة بين الصفحتين
  const SUPABASE_URL = 'https://dupdkohciluepwrfuhod.supabase.co';
  const SUPABASE_ANON_KEY = 'sb_publishable_UVbMT7eplHHBNdZbOpLssw_UUEYTxFA';
  const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  let currentLang = localStorage.getItem('raseekh_lang') || 'ar';

  function applyLanguage(lang){
    currentLang = lang;
    localStorage.setItem('raseekh_lang', lang);
    const html = document.getElementById('htmlRoot');
    html.lang = lang;
    html.dir = lang === 'ar' ? 'rtl' : 'ltr';
    document.body.classList.toggle('lang-en', lang === 'en');

    document.querySelectorAll('[data-ar][data-en]').forEach(el => {
      el.textContent = lang === 'ar' ? el.getAttribute('data-ar') : el.getAttribute('data-en');
    });
    document.querySelectorAll('[data-ar-ph][data-en-ph]').forEach(el => {
      el.setAttribute('placeholder', lang === 'ar' ? el.getAttribute('data-ar-ph') : el.getAttribute('data-en-ph'));
    });

    document.getElementById('pageTitle').textContent = lang === 'ar'
      ? 'لوحة تحكم العميل — رَسِيخ'
      : 'Customer Dashboard — Raseekh';

    renderRequestsTable();
    renderInvoicesDemo();
    renderFaqDemo();
    renderStats();
  }

  let currentUser = null;
  let allRequests = [];
  let currentFilter = 'all';

  function escapeHtml(str){
    const div = document.createElement('div');
    div.textContent = str == null ? '' : String(str);
    return div.innerHTML;
  }

  let toastTimer;
  function showToast(msg){
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 3200);
  }

  // تعبئة بيانات المستخدم وعرض لوحة التحكم
  function showDashboard(user){
    currentUser = user;

    const email = user?.email || '';
    const displayName = user?.user_metadata?.full_name || user?.user_metadata?.display_name || '';
    document.getElementById('dashUserEmail').textContent = displayName || email || '—';
    document.getElementById('dashAvatarInitial').textContent = (displayName || email || '؟').trim().charAt(0).toUpperCase();
    document.getElementById('settingsEmail').value = email;
    document.getElementById('settingsName').value = displayName;
    document.getElementById('activityNow').textContent = new Date().toLocaleString(currentLang === 'ar' ? 'ar-SA' : 'en-US');

    applyLanguage(currentLang);
    startClock();
    loadRequests();
    renderInvoicesDemo();
    renderFaqDemo();
    switchPage('overview');
  }

  function switchPage(page){
    document.querySelectorAll('.dash-nav-item').forEach(b => b.classList.toggle('active', b.dataset.page === page));
    document.querySelectorAll('.dash-page').forEach(p => p.classList.remove('active'));
    const target = document.getElementById('page-' + page);
    if (!target) return;
    void target.offsetWidth;
    target.classList.add('active');
  }
  document.querySelectorAll('.dash-nav-item').forEach(btn => {
    btn.addEventListener('click', () => switchPage(btn.dataset.page));
  });
  document.querySelectorAll('[data-goto]').forEach(el => {
    el.addEventListener('click', () => switchPage(el.dataset.goto));
  });

  // تسجيل الخروج — يرجّع المستخدم للصفحة الرئيسية
  document.getElementById('dashLogoutBtn').addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = 'index.html';
  });

  function startClock(){
    function tick(){
      const el = document.getElementById('dashClock');
      if (el) el.textContent = new Date().toLocaleTimeString(currentLang === 'ar' ? 'ar-SA' : 'en-US');
    }
    tick();
    clearInterval(window._dashClockInterval);
    window._dashClockInterval = setInterval(tick, 1000);
  }

  function localReqKey(){ return 'raseekh_requests_' + (currentUser?.id || 'guest'); }
  function getLocalRequests(){
    try { return JSON.parse(localStorage.getItem(localReqKey())) || []; }
    catch(e){ return []; }
  }
  function saveLocalRequests(list){
    localStorage.setItem(localReqKey(), JSON.stringify(list));
  }

  async function loadRequests(){
    const holder = document.getElementById('requestsTableHolder');
    holder.innerHTML = renderSkeletonRows();
    try {
      const { data, error } = await supabase
        .from('customer_requests')
        .select('*')
        .eq('user_id', currentUser.id)
        .order('created_at', { ascending: false });
      if (error) throw error;
      allRequests = data || [];
    } catch (e) {
      // جدول customer_requests غير موجود بعد في Supabase — نستخدم تخزين محلي مؤقت للعرض
      allRequests = getLocalRequests();
    }
    renderStats();
    renderRequestsTable();
  }

  function renderSkeletonRows(){
    let html = '<div style="padding:20px 24px; display:flex; flex-direction:column; gap:14px;">';
    for (let i=0;i<3;i++) html += '<div class="skeleton" style="height:20px; width:100%;"></div>';
    html += '</div>';
    return html;
  }

  function statusMeta(status){
    const map = {
      pending:  { ar:'قيد المراجعة', en:'Pending',     cls:'pending'  },
      progress: { ar:'قيد التنفيذ',  en:'In Progress',  cls:'progress' },
      done:     { ar:'مكتمل',        en:'Done',         cls:'done'     },
      rejected: { ar:'مرفوض',        en:'Rejected',     cls:'rejected' }
    };
    return map[status] || map.pending;
  }

  function renderRequestsTable(){
    const holder = document.getElementById('requestsTableHolder');
    const filtered = currentFilter === 'all' ? allRequests : allRequests.filter(r => (r.status || 'pending') === currentFilter);

    if (!filtered.length){
      holder.innerHTML = `<div class="empty-state">
        <div class="es-icon">📭</div>
        <p>${currentLang === 'ar' ? 'ما عندك أي طلبات هنا بعد. اضغط "طلب جديد" عشان تبدأ.' : 'No requests here yet. Click "New Request" to get started.'}</p>
      </div>`;
      return;
    }

    let rows = '';
    filtered.forEach((r, i) => {
      const meta = statusMeta(r.status || 'pending');
      const label = currentLang === 'ar' ? meta.ar : meta.en;
      const title = r.title || '—';
      const type = r.system_type || r.type || '—';
      const dateStr = new Date(r.created_at || Date.now()).toLocaleDateString(currentLang === 'ar' ? 'ar-SA' : 'en-US');
      rows += `<tr style="animation-delay:${i * 0.05}s">
        <td class="req-id">#${String(r.id).slice(-5)}</td>
        <td>${escapeHtml(title)}${r.phone ? `<br><span class="mono" style="color:var(--muted); font-size:11.5px;">${escapeHtml(r.phone)}</span>` : ''}</td>
        <td>${escapeHtml(type)}</td>
        <td class="mono">${dateStr}</td>
        <td><span class="badge ${meta.cls}">${label}</span></td>
        <td>
          <div class="row-actions">
            <button class="row-action-btn" data-action="edit" data-id="${r.id}" title="${currentLang === 'ar' ? 'تعديل' : 'Edit'}">✎</button>
            <button class="row-action-btn danger" data-action="delete" data-id="${r.id}" title="${currentLang === 'ar' ? 'حذف' : 'Delete'}">🗑</button>
          </div>
        </td>
      </tr>`;
    });

    holder.innerHTML = `<table class="req-table">
      <thead><tr>
        <th>#</th>
        <th>${currentLang === 'ar' ? 'العنوان' : 'Title'}</th>
        <th>${currentLang === 'ar' ? 'النوع' : 'Type'}</th>
        <th>${currentLang === 'ar' ? 'التاريخ' : 'Date'}</th>
        <th>${currentLang === 'ar' ? 'الحالة' : 'Status'}</th>
        <th>${currentLang === 'ar' ? 'الإجراءات' : 'Actions'}</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
  }

  // Edit / delete a request (event delegation on the table container)
  document.getElementById('requestsTableHolder').addEventListener('click', (e) => {
    const btn = e.target.closest('.row-action-btn');
    if (!btn) return;
    const id = btn.dataset.id;
    if (btn.dataset.action === 'edit') openEditRequestModal(id);
    if (btn.dataset.action === 'delete') deleteRequest(id);
  });

  let editingRequestId = null;

  function openEditRequestModal(id){
    const req = allRequests.find(r => String(r.id) === String(id));
    if (!req) return;
    editingRequestId = id;
    document.getElementById('nr_name').value = req.customer_name || '';
    document.getElementById('nr_phone').value = req.phone || '';
    document.getElementById('nr_title').value = req.title || '';
    document.getElementById('nr_type').value = req.system_type || req.type || '';
    document.getElementById('nr_desc').value = req.description || '';
    document.getElementById('reqModalTitle').textContent = currentLang === 'ar' ? 'تعديل الطلب' : 'Edit Request';
    document.getElementById('reqModalSubmitBtn').textContent = currentLang === 'ar' ? 'حفظ التعديلات' : 'Save Changes';
    newReqModal.classList.add('active');
  }

  async function deleteRequest(id){
    const ok = confirm(currentLang === 'ar' ? 'متأكد تبي تحذف هذا الطلب؟' : 'Are you sure you want to delete this request?');
    if (!ok) return;
    try {
      const { error } = await supabase.from('customer_requests').delete().eq('id', id);
      if (error) throw error;
    } catch (err) {
      // إذا الجدول غير موجود بعد، نحذف من التخزين المحلي فقط
    }
    allRequests = allRequests.filter(r => String(r.id) !== String(id));
    saveLocalRequests(allRequests.filter(r => String(r.id).startsWith('local-')));
    renderStats();
    renderRequestsTable();
    showToast(currentLang === 'ar' ? 'تم حذف الطلب' : 'Request deleted');
  }

  document.getElementById('reqFilters').addEventListener('click', (e) => {
    const btn = e.target.closest('.filter-chip');
    if (!btn) return;
    document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    currentFilter = btn.dataset.filter;
    renderRequestsTable();
  });

  // Overview stat cards + progress ring
  function renderStats(){
    const total = allRequests.length;
    const progress = allRequests.filter(r => r.status === 'progress').length;
    const done = allRequests.filter(r => r.status === 'done').length;
    animateCount('statTotal', total);
    animateCount('statProgress', progress);
    animateCount('statDone', done);
    animateCount('statWarranty', 30);
    const pct = total ? Math.round((done / total) * 100) : 0;
    updateProgressRing(pct, total > 0);
  }

  function animateCount(id, target){
    const el = document.getElementById(id);
    if (!el) return;
    const duration = 900;
    const startTime = performance.now();
    function step(now){
      const p = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(target * eased);
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function updateProgressRing(pct, hasProject){
    const circle = document.getElementById('progressRingCircle');
    const text = document.getElementById('progressRingText');
    const sub = document.getElementById('progressRingSub');
    const circumference = 377;
    circle.style.strokeDashoffset = circumference - (circumference * pct / 100);
    text.textContent = pct + '%';
    sub.textContent = hasProject
      ? (currentLang === 'ar' ? 'من طلباتك تم إنجازها' : 'of your requests completed')
      : (currentLang === 'ar' ? 'بدون مشروع نشط' : 'No active project');
  }

  // New request modal
  const newReqModal = document.getElementById('newReqModal');
  document.getElementById('newReqBtn').addEventListener('click', () => {
    editingRequestId = null;
    document.getElementById('newReqForm').reset();
    document.getElementById('nr_name').value = currentUser?.user_metadata?.display_name || '';
    document.getElementById('reqModalTitle').textContent = currentLang === 'ar' ? 'طلب جديد' : 'New Request';
    document.getElementById('reqModalSubmitBtn').textContent = currentLang === 'ar' ? 'إرسال الطلب' : 'Submit Request';
    newReqModal.classList.add('active');
  });
  document.getElementById('newReqClose').addEventListener('click', () => newReqModal.classList.remove('active'));

  document.getElementById('newReqForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const customer_name = document.getElementById('nr_name').value.trim();
    const phone = document.getElementById('nr_phone').value.trim();
    const title = document.getElementById('nr_title').value.trim();
    const type = document.getElementById('nr_type').value;
    const description = document.getElementById('nr_desc').value.trim();

    // رقم الجوال والاسم إجباريين — بدونهم ما يتم إرسال أو تعديل الطلب
    if (!customer_name || !phone) {
      showToast(currentLang === 'ar' ? 'الاسم ورقم الجوال مطلوبين لإرسال الطلب' : 'Name and phone number are required');
      return;
    }

    if (editingRequestId) {
      // ------- EDIT MODE: update an existing request -------
      try {
        const { data, error } = await supabase
          .from('customer_requests')
          .update({ customer_name, phone, title, system_type: type, description })
          .eq('id', editingRequestId)
          .select();
        if (error) throw error;
        const idx = allRequests.findIndex(r => String(r.id) === String(editingRequestId));
        if (idx > -1) allRequests[idx] = data[0];
      } catch (err) {
        // جدول غير موجود بعد أو الطلب محلي — نحدّث النسخة المحلية مباشرة
        const idx = allRequests.findIndex(r => String(r.id) === String(editingRequestId));
        if (idx > -1) {
          allRequests[idx] = { ...allRequests[idx], customer_name, phone, title, system_type: type, description };
          saveLocalRequests(allRequests.filter(r => String(r.id).startsWith('local-')));
        }
      }
      showToast(currentLang === 'ar' ? 'تم حفظ التعديلات ✅' : 'Changes saved ✅');
    } else {
      // ------- CREATE MODE: new request -------
      const fallbackReq = {
        id: 'local-' + Date.now(),
        customer_name, phone, title, system_type: type, description,
        status: 'pending', created_at: new Date().toISOString(),
        user_id: currentUser?.id
      };
      try {
        const { data, error } = await supabase
          .from('customer_requests')
          .insert([{ customer_name, phone, title, system_type: type, description, status: 'pending', user_id: currentUser.id }])
          .select();
        if (error) throw error;
        allRequests.unshift(data[0]);
      } catch (err) {
        allRequests.unshift(fallbackReq);
        saveLocalRequests(allRequests.filter(r => String(r.id).startsWith('local-')));
      }
      showToast(currentLang === 'ar' ? 'تم إرسال طلبك بنجاح ✅' : 'Your request was submitted ✅');
    }

    editingRequestId = null;
    newReqModal.classList.remove('active');
    document.getElementById('newReqForm').reset();
    renderStats();
    renderRequestsTable();
  });

  // Invoices — demo content until a real "invoices" table is connected
  function renderInvoicesDemo(){
    const holder = document.getElementById('invoicesHolder');
    const demo = [
      { id:'INV-1042', d:{ar:'دفعة أولى — نظام إدارة عملاء', en:'First payment — Customer Management System'}, amount:'1,200', status:'paid', date:'2026-05-02' },
      { id:'INV-1043', d:{ar:'دفعة ثانية — نظام إدارة عملاء', en:'Second payment — Customer Management System'}, amount:'1,200', status:'pending', date:'2026-07-01' }
    ];
    holder.innerHTML = demo.map(inv => `
      <div class="invoice-row">
        <div class="invoice-info">
          <p>${currentLang === 'ar' ? inv.d.ar : inv.d.en}</p>
          <span>${inv.id} · ${inv.date}</span>
        </div>
        <div style="display:flex; align-items:center; gap:14px;">
          <span class="invoice-amount">${inv.amount} ${currentLang === 'ar' ? 'ر.س' : 'SAR'}</span>
          <span class="badge ${inv.status === 'paid' ? 'done' : 'pending'}">${inv.status === 'paid' ? (currentLang === 'ar' ? 'مدفوعة' : 'Paid') : (currentLang === 'ar' ? 'مستحقة' : 'Due')}</span>
        </div>
      </div>
    `).join('');
  }

  // Support FAQ — demo accordion content
  function renderFaqDemo(){
    const holder = document.getElementById('faqHolder');
    const faqs = [
      { q:{ar:'كم يستغرق تطوير نظام مخصص؟', en:'How long does building a custom system take?'},
        a:{ar:'يعتمد على حجم النظام، لكن غالباً بين 3 إلى 8 أسابيع من التصميم للتسليم.', en:'It depends on system size, but usually 3–8 weeks from design to delivery.'} },
      { q:{ar:'هل أقدر أطلب تعديلات بعد التسليم؟', en:'Can I request changes after delivery?'},
        a:{ar:'نعم، ضمن ضمان التشغيل لمدة 30 يوم، وبعدها عبر باقات صيانة اختيارية.', en:'Yes, within the 30-day warranty, and afterward through optional maintenance plans.'} },
      { q:{ar:'كيف أتواصل مع فريق الدعم؟', en:'How do I reach the support team?'},
        a:{ar:'اضغط "فتح تذكرة دعم" أعلى الصفحة وبنرد عليك خلال يوم عمل.', en:'Click "Open a Ticket" above and we will respond within one business day.'} }
    ];
    holder.innerHTML = faqs.map(f => `
      <div class="faq-item">
        <div class="faq-q"><span>${currentLang === 'ar' ? f.q.ar : f.q.en}</span><span class="faq-arrow">⌄</span></div>
        <div class="faq-a">${currentLang === 'ar' ? f.a.ar : f.a.en}</div>
      </div>
    `).join('');
    holder.querySelectorAll('.faq-q').forEach(q => q.addEventListener('click', () => q.parentElement.classList.toggle('open')));
  }

  document.getElementById('openTicketBtn').addEventListener('click', () => {
    showToast(currentLang === 'ar' ? 'تم فتح تذكرة دعم! بيتواصل معك فريقنا قريباً.' : 'Support ticket opened! Our team will reach out soon.');
  });

  // Settings — update display name / password via Supabase Auth
  document.getElementById('settingsForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('settingsName').value.trim();
    const pass = document.getElementById('settingsPassword').value;
    try {
      const updates = {};
      if (pass) updates.password = pass;
      if (name) updates.data = { display_name: name };
      if (Object.keys(updates).length) {
        const { error } = await supabase.auth.updateUser(updates);
        if (error) throw error;
      }
      showToast(currentLang === 'ar' ? 'تم حفظ التغييرات ✅' : 'Changes saved ✅');
      document.getElementById('settingsPassword').value = '';
      if (name) document.getElementById('dashUserEmail').textContent = name;
    } catch (err) {
      showToast(err.message);
    }
  });

  // هذه الصفحة تتطلب تسجيل دخول — إذا ما فيه جلسة نشطة، نرجّع الزائر للصفحة الرئيسية
  (async function initSession(){
    try {
      const { data } = await supabase.auth.getSession();
      if (data?.session?.user) {
        showDashboard(data.session.user);
      } else {
        window.location.href = 'index.html';
      }
    } catch(e) {
      window.location.href = 'index.html';
    }
  })();

  // إذا سجّل المستخدم خروج من نافذة/تبويب ثاني، رجّعه للصفحة الرئيسية هنا كمان
  supabase.auth.onAuthStateChange((event) => {
    if (event === 'SIGNED_OUT') window.location.href = 'index.html';
  });

</script>
</body>
</html>
